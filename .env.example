# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=0

# Security
SECRET_KEY=change-me-to-a-secure-random-string

# Database (optional - defaults to SQLite in instance/laptops.db)
# DATABASE_URL=sqlite:////home/yourusername/devices_borrowing_system/instance/laptops.db

# Borrower Settings
REQUIRE_BORROWER_EMAIL=1

# Email Configuration (optional - if you want email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
